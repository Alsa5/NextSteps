# Server
Port=3001
NodeEnv=development
CorsOrigin=http://localhost:5173
JwtSecret=dev-only-change-me

# MongoDB — same cluster as Sanctuary, separate database
MongoDbUri=mongodb://127.0.0.1:27017
MongoDbDatabase=nextsteps

# Azure AD — same app registration as Sanctuary (copy secret from sanctuary-api .env)
AzureTenantId=7c0c36f5-af83-4c24-8844-9962e0163719
AzureClientId=7c5e05a2-7978-4c21-81e0-9a39257cb0c1
AzureClientSecret=

# Legacy aliases (same as sanctuary-api)
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# App administrators — comma-separated emails allowed to switch all four roles
AppAdminEmails=sakthia2@hexaware.com,2000147951@hexaware.com

REDIS_URL=redis://127.0.0.1:6379
# Set to false for local dev without Redis (SSO/API still work; background jobs disabled)
REDIS_ENABLED=true

# Google Meet OAuth (ALSAA-20 stub)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3001/api/v1/integrations/google-meet/oauth/callback
GOOGLE_MEET_WORKSPACE_DOMAIN=
GOOGLE_MEET_STUB_MODE=true
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/meetings.space.readonly
