# Azure App Service → Configuration → Application settings
# Option B: Key Vault reference for Cosmos (same pattern as Sanctuary).
# Do not commit real secrets. App Service injects PORT automatically.

# ── Required ──────────────────────────────────────────────────────────────────
NODE_ENV=production

# Cosmos connection string from Key Vault (resolved at runtime by App Service MI).
# Same secret Sanctuary uses (sc-kv-devtest / MongoDbUri). Get the SecretUri from:
#   Azure Portal → Key Vault → Secrets → MongoDbUri → Secret Identifier
MONGODB_URI=@Microsoft.KeyVault(SecretUri=https://sc-kv-devtest.vault.azure.net/secrets/MongoDbUri/)

# NextSteps database on the shared Cosmos cluster (Sanctuary uses "sanctuary").
MONGODB_DATABASE=nextsteps

JWT_SECRET=
CORS_ORIGIN=https://your-app-name.azurewebsites.net
APP_PUBLIC_URL=https://your-app-name.azurewebsites.net
AZURE_TENANT_ID=7c0c36f5-af83-4c24-8844-9962e0163719
AZURE_CLIENT_ID=7c5e05a2-7978-4c21-81e0-9a39257cb0c1
AZURE_CLIENT_SECRET=

# ── App Service setup (portal, not env vars) ─────────────────────────────────
# 1. Enable system-assigned managed identity on the Web App
# 2. Key Vault → Access control → grant MI "Key Vault Secrets User" on sc-kv-devtest
# 3. Cosmos → grant MI Cosmos DB Built-in Data Contributor (or use Entra connection string in secret)
# 4. Startup command: node dist/index.js

# ── Admin / RBAC ──────────────────────────────────────────────────────────────
APP_ADMIN_EMAILS=sakthia2@hexaware.com,2000147951@hexaware.com

# ── Redis (background workers — recommended in production) ──────────────────
REDIS_URL=
REDIS_ENABLED=true

# ── Azure OpenAI (AI Buddy, transcript analysis, L&D AI helper) ───────────────
AzureOpenAIEndpoint=
AzureOpenAIKey=
AzureOpenAIDeployment=gpt-5
AzureOpenAIApiVersion=2025-01-01-preview

# ── SMTP (magic-link OTP, onboarding mail, session invites) ─────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
MAIL_FROM=
SMTP_TLS_INSECURE=false

# ── Google Meet / Calendar OAuth (L&D pre-onboarding sessions) ────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-app-name.azurewebsites.net/api/v1/integrations/google/oauth/callback
GOOGLE_MEET_WORKSPACE_DOMAIN=
GOOGLE_MEET_STUB_MODE=true
GOOGLE_OAUTH_SCOPES=https://www.googleapis.com/auth/meetings.space.readonly
